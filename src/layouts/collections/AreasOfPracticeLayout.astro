---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SecondaryHero from "@/layouts/SecondaryHero.astro";
import ContactFormSection from "@/layouts/ContactFormSection.astro";
import AreaOfPracticeSidebar from "@/components/AreaOfPracticeSidebar.astro";
import type { CollectionLayoutProps } from "./types";

const {
  entry,
  Content,
  seoProps = {},
} = Astro.props as CollectionLayoutProps;

const data = entry?.data || {};
const currentSlug = entry?.slug ?? entry?.id ?? "";

const practiceTitle =
  typeof data.title === "string" && data.title.trim().length > 0
    ? data.title.trim()
    : "This Practice Area";
const inquiryTitle = `Request Guidance on ${practiceTitle}`;
const inquiryDescription = `Tell us about your ${practiceTitle} matter and we will follow up with the attention, discretion, and practical judgment it requires.`;
const inquiryHiddenFields = {
  sourceCollection: "areas-of-practice",
  sourcePage: currentSlug,
  sourceTitle: practiceTitle,
  sourcePath: `/${currentSlug}`,
  inquiryContext: `areas-of-practice:${currentSlug}`,
};
---

<BaseLayout {...seoProps}>
  <SecondaryHero
    slot="hero"
    eyebrow="Areas of Practice"
    title={practiceTitle}
    description={data.description}
    image={data.bannerImage}
    publishDate={data.publishDate}
    author={data.author}
    readingTime={data.readingTime}
  />

  <main class="flex-1">
    <div class="mx-auto w-full px-6 py-10 sm:px-10 md:px-12 md:py-12 lg:px-16 lg:py-16 xl:px-20">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] lg:items-start lg:gap-10 xl:grid-cols-[minmax(0,1fr)_24rem]">
        <div class="order-2 lg:order-1">
          <div class="mb-8 lg:hidden">
            <AreaOfPracticeSidebar
              inquiryHref="#practice-inquiry"
              mobile={true}
            />
          </div>

          {Content && (
            <article data-practice-content>
              <Content />
            </article>
          )}
        </div>

        <aside class="order-1 hidden lg:block lg:sticky lg:top-28">
          <AreaOfPracticeSidebar
            inquiryHref="#practice-inquiry"
          />
        </aside>
      </div>

      <ContactFormSection
        id="practice-inquiry"
        className="pt-16 lg:pt-20"
        title={inquiryTitle}
        description={inquiryDescription}
        defaultPracticeArea={currentSlug}
        hidePracticeAreaField={true}
        hiddenFields={inquiryHiddenFields}
      />
    </div>
  </main>
</BaseLayout>
