---
// src/layouts/FrontPageHero.astro
/**
 * Front Page Hero Layout
 *
 * Full-width hero section with optimized background media for homepage.
 *
 * Features:
 * - Responsive background images with LCP optimization
 * - Optional video background with poster image
 * - Large centered text with gradient overlay
 * - Primary and secondary CTAs
 * - Responsive minimum height with full-screen mobile layout
 * - Supports both static images and video backgrounds
 *
 * This is a layout component for landing pages.
 * Use directly in your homepage or marketing pages.
 */

import Button from "@/components/Button/Button";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import HeroQuoteCard from "@/components/HeroQuoteCard.astro";
import PhoneNumberButton from "@/components/PhoneNumberButton.astro";
import { sharedPhoneNumberButtonProps } from "@/components/phoneNumberButtonConfig";
import SectionHeading from "@/components/SectionHeading.astro";
import BackgroundMedia from "@/components/BackgroundMedia.astro";
import { ctaData } from "@/content/siteData";
import { animationProps } from "@/integrations/scroll-animations";
import { query } from "@/utils/query";
import DefaultImg from "@/assets/background.svg";
import JerryHymanson from "@/assets/jerry-hymanson.jpg";

export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  image?: any; // Astro image asset or public path
  video?: {
    src: string;
    autoPlay?: boolean;
    muted?: boolean;
    loop?: boolean;
    playsInline?: boolean;
    controls?: boolean;
    preload?: string;
  };
  primaryCTA?: {
    text: string;
    link: string;
  };
  secondaryCTA?: {
    text: string;
    link: string;
  };
  className?: string;
  id?: string;
}

const {
  eyebrow = "Established Excellence",
  title = "Welcome",
  description,
  image,
  video,
  primaryCTA = {
    text: ctaData.text,
    link: ctaData.link,
  },
  className = "",
  id = "hero",
} = Astro.props;

// Prepare optimized background media
const backgroundMedia = {
  image: {
    src: image || DefaultImg,
    imageClass: "bg-cover bg-center lg:bg-fixed",
    aboveTheFold: true, // Front page hero is always LCP
  },
  video: video
    ? {
        src: video.src,
        autoPlay: video.autoPlay ?? true,
        muted: video.muted ?? true,
        loop: video.loop ?? true,
        playsInline: video.playsInline ?? true,
        controls: video.controls ?? false,
        preload: video.preload ?? "metadata",
        videoClass: "object-cover",
      }
    : undefined,
  overlayClass: "bg-gradient-to-b from-black/30 to-black/60",
};

const headingAnimation = animationProps("fade-in-up", {
  once: true,
});

const ctaAnimation = animationProps("fade-in-up", {
  once: true,
  delay: 180,
});

const quoteCardAnimation = animationProps("fade-in-left", {
  once: true,
  delay: 280,
});

---

<section id={id} class={`relative ${className}`}>
  <div class="relative overflow-hidden px-4 pb-16 pt-24 sm:px-6 sm:pb-20 sm:pt-28 lg:flex lg:min-h-[140vh] lg:items-center lg:justify-start lg:px-0 lg:py-0">
    {/* Optimized background media with overlay */}
    <BackgroundMedia backgroundMedia={backgroundMedia} />
    <div class="hero-image-wash absolute inset-0 z-[1]" aria-hidden="true"></div>

    {/* Hero Content */}
    <div class="relative z-10 flex min-h-[80vh] w-full max-w-xl flex-col justify-center text-left sm:max-w-2xl lg:min-h-0 lg:max-w-3xl lg:px-12 xl:ml-16 xl:px-0">
      <div {...headingAnimation}>
        <SectionHeading
          as="h1"
          eyebrow={eyebrow}
          description={description}
          className="max-w-3xl"
          descriptionClass="mb-6 max-w-[24rem] text-lg leading-relaxed text-text sm:max-w-[28rem] md:max-w-[32rem] md:text-xl"
        >
          <Fragment slot="title">
            <slot name="title">{title}</slot>
          </Fragment>
        </SectionHeading>
      </div>

      {/* CTA Buttons */}
      <div {...ctaAnimation} class="flex flex-wrap justify-start gap-4 lg:gap-12">
        {
          primaryCTA && (
            <Button
              href={primaryCTA.link}
              variant="primary"
              size="lg"
              rightIcon="lu:arrow-right"
              className="shadow-xl hover:shadow-2xl transition-shadow"
            >
              {primaryCTA.text}
            </Button>
          )
        }

        <PhoneNumberButton {...sharedPhoneNumberButtonProps} />
      </div>
    </div>

    <div
      class="pointer-events-none relative z-10 mt-8 w-full max-w-[34rem] self-center lg:absolute lg:bottom-4 lg:right-4 lg:mt-0"
    >
      <div
        {...quoteCardAnimation}
        class="hero-quote-reveal pointer-events-auto"
      >
        <HeroQuoteCard
          className="pointer-events-auto"
          portraitSrc={JerryHymanson.src}
          portraitAlt="Jerry Hymanson"
        />
      </div>
      <ContentRenderer
        query={query("stats")}
        variant="StatsVariant"
        className="pointer-events-auto mt-4"
      />
    </div>
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</section>

<script>
  const root = document.documentElement;

  if (!root.dataset.heroQuoteReady) {
    const unlockQuote = () => {
      root.dataset.heroQuoteReady = "true";
      window.removeEventListener("scroll", onFirstDownScroll);
    };

    let lastScrollY = window.scrollY;

    const onFirstDownScroll = () => {
      const currentScrollY = window.scrollY;

      if (currentScrollY > 0 && currentScrollY > lastScrollY) {
        unlockQuote();
        return;
      }

      lastScrollY = currentScrollY;
    };

    if (window.scrollY > 0) {
      unlockQuote();
    } else {
      window.addEventListener("scroll", onFirstDownScroll, { passive: true });
    }
  }
</script>

<style>
  h1,
  p {
    text-shadow: none;
  }

  :root:not([data-hero-quote-ready="true"]) .hero-quote-reveal {
    opacity: 0 !important;
    transform: translateX(-30px) !important;
    pointer-events: none;
  }
</style>
