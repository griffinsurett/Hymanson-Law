---
// src/layouts/SecondaryHero.astro
/**
 * Secondary Hero Layout
 *
 * Full-width hero with optimized background media support.
 * Uses BackgroundMedia component for responsive image optimization.
 *
 * Features:
 * - Responsive background images (mobile/tablet/desktop)
 * - Automatic LCP optimization with aboveTheFold
 * - Gradient overlay for text readability
 * - Optional metadata display (date, author, reading time)
 */

import { getAuthorName } from "@/layouts/collections/helpers/layoutHelpers";
import BackgroundMedia from "@/components/BackgroundMedia.astro";
import BuildingsHeroImage from "@/assets/buildings.jpg";

export interface Props {
  title: string;
  eyebrow?: string;
  description?: string;
  image?: any; // Astro image asset or public path
  publishDate?: Date | string;
  author?: string | { collection: string; id: string };
  readingTime?: number;
  className?: string;
}

const {
  title,
  eyebrow,
  description,
  image,
  publishDate,
  author,
  readingTime,
  className = "",
} = Astro.props;

// Prepare optimized background media
const backgroundMedia = {
  image: {
    src: image || BuildingsHeroImage,
    imageClass: "bg-cover bg-center lg:bg-fixed",
    aboveTheFold: true, // Automatic LCP optimization
  },
  overlayClass: "bg-gradient-to-b from-black/30 to-black/60",
};
---

<section class={`relative ${className}`}>
  <div
    class="relative flex min-h-[80vh] items-center overflow-hidden px-6 pb-14 pt-24 sm:px-10 sm:pb-16 sm:pt-28 lg:px-16 lg:py-0 xl:px-20"
  >
    {/* Optimized background with overlay */}
    <BackgroundMedia backgroundMedia={backgroundMedia} />
    <div class="hero-image-wash absolute inset-0 z-[1]" aria-hidden="true"></div>

    {/* Hero content */}
    <div class="relative z-10 mx-auto flex w-full max-w-[80rem] items-center">
      <div class="max-w-4xl text-left">
        {
          eyebrow && (
            <p class="mb-4 text-sm font-semibold uppercase tracking-[0.28em] text-secondary [text-shadow:none]">
              {eyebrow}
            </p>
          )
        }

        <h1
          class="font-newsreader text-[3rem] leading-[0.94] tracking-[-0.03em] text-heading [text-shadow:none] md:text-[4rem] lg:text-[5rem] xl:text-[5.5rem]"
        >
          {title}
        </h1>

        {
          description && (
            <p class="mt-6 max-w-3xl text-lg leading-relaxed text-text [text-shadow:none] md:text-xl">
              {description}
            </p>
          )
        }

        {/* Metadata row with icons */}
        {
          (publishDate || author || readingTime) && (
            <div class="mt-8 flex flex-wrap gap-4 text-sm text-heading/80 md:gap-6 md:text-base">
              {publishDate && (
                <time
                  datetime={new Date(publishDate).toISOString()}
                  class="flex items-center gap-2"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                    />
                  </svg>
                  {new Date(publishDate).toLocaleDateString()}
                </time>
              )}

              {author && (
                <span class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    />
                  </svg>
                  By {getAuthorName(author)}
                </span>
              )}

              {readingTime && (
                <span class="flex items-center gap-2">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  {readingTime} min read
                </span>
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>

  {/* Optional slot for additional content below hero */}
  <slot />
</section>
