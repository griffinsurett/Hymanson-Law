---
// src/layouts/Footer.astro
/**
 * Footer Component
 *
 * Site-wide footer with branded firm details, office/contact columns,
 * legal links, and user preference controls.
 */
import { Image } from "astro:assets";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import PhoneNumberButton from "@/components/PhoneNumberButton.astro";
import FooterLogo from "@/assets/logo-hymanson-transparent-white.png";
import { siteData } from "@/content/siteData";
import { getCollectionMeta, prepareCollectionEntries } from "@/utils/collections";
import { query, sortByOrder } from "@/utils/query";
import PreferencesLayout from "./PreferencesLayout.astro";

const legalEntries = await query("legal").all();
const practiceEntries = await query("areas-of-practice").orderBy(sortByOrder()).all();
const servedLocationEntries = await query("where-we-serve").orderBy(sortByOrder()).all();

const legalLinks = await prepareCollectionEntries(
  legalEntries,
  "legal",
  getCollectionMeta("legal"),
);
const practiceLinks = await prepareCollectionEntries(
  practiceEntries,
  "areas-of-practice",
  getCollectionMeta("areas-of-practice"),
);
const servedLocationLinks = await prepareCollectionEntries(
  servedLocationEntries,
  "where-we-serve",
  getCollectionMeta("where-we-serve"),
);
---

<footer class="mt-auto bg-[linear-gradient(135deg,#020b16_0%,#08335d_100%)] text-white">
  <div class="mx-auto w-full px-6 md:px-10 lg:px-16">
    <div class="grid gap-12 md:grid-cols-2 xl:grid-cols-[minmax(0,1.15fr)_repeat(3,minmax(0,1fr))] xl:gap-10 py-8 lg:pt-16">
      <div class="max-w-sm">
        <a
          href="/"
          class="inline-flex items-center transition-opacity duration-200 hover:opacity-85"
          aria-label={siteData.title}
        >
          <Image
            src={FooterLogo}
            alt="Hymanson Law logo"
            width={132}
            height={132}
            format="png"
            class="h-24 w-24 object-contain sm:h-28 sm:w-28"
          />
        </a>

        <p class="mt-6 max-w-xs text-base leading-8 text-white/86 sm:text-[1.0625rem]">
          {siteData.footer.description}
        </p>
        <div class="mt-8">
          <PhoneNumberButton
            desktopMode="link"
            iconSize="md"
            className="!text-bg transition-colors duration-200 hover:!text-white"
            textClass="!text-bg text-base leading-none md:text-lg lg:text-xl"
          />
        </div>
      </div>

      <div>
        <p class="text-xs font-medium tracking-[0.32em] text-white/70 uppercase">
          Menu
        </p>
        <nav aria-label="Footer menu" class="mt-5">
          <ul class="space-y-4 text-lg leading-8 text-white/92">
            {siteData.footer.menuLinks.map((link) => (
              <li>
                <a class="transition-colors duration-200 hover:text-white" href={link.href}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <div>
        <p class="text-xs font-medium tracking-[0.32em] text-white/70 uppercase">
          Areas of Practice
        </p>
        <ContentRenderer
          items={practiceLinks}
          variant="ListVariant"
          className="footer-list-variant py-0"
        />
      </div>

      <div>
        <p class="text-xs font-medium tracking-[0.32em] text-white/70 uppercase">
          Where We Serve
        </p>
        <ContentRenderer
          items={servedLocationLinks}
          variant="ListVariant"
          className="footer-list-variant py-0"
        />
      </div>
    </div>

    <div class="py-7 text-sm text-white/78">
      <PreferencesLayout className="justify-start md:justify-center" />

      <nav aria-label="Mobile legal footer links" class="mt-5 md:hidden">
        <ul class="flex flex-col items-start gap-3 text-sm leading-6 text-white/78">
          {legalLinks.map((item) => (
            <li>
              <a class="transition-colors duration-200 hover:text-white" href={item.url}>
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="border-t py-5 border-white/20">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <p class="text-sm leading-6 text-white/78">
          &copy; {new Date().getFullYear()} {siteData.legalName}. All Rights Reserved. Built by{" "}
          <a
            href="https://griffinswebservices.com"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold underline-offset-4 transition hover:text-white hover:underline"
          >
            Griffin&apos;s Web Services
          </a>
        </p>

        <nav aria-label="Legal footer links">
          <ul class="hidden md:flex flex-wrap items-center gap-x-8 gap-y-3 text-sm leading-6 text-white/78">
            {legalLinks.map((item) => (
              <li>
                <a class="transition-colors duration-200 hover:text-white" href={item.url}>
                  {item.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .footer-list-variant nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .footer-list-variant .link-base {
    color: rgb(255 255 255 / 0.92);
    font-family: var(--font-plus-jakarta);
    font-optical-sizing: auto;
    font-size: 1.125rem;
    line-height: 2rem;
    font-weight: 400;
    text-decoration: none;
  }

  .footer-list-variant .link-base:hover {
    color: white;
    text-decoration: none;
  }
</style>
