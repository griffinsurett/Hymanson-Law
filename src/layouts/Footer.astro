---
// src/layouts/Footer.astro
/**
 * Footer Component
 *
 * Site-wide footer with branded firm details, office/contact columns,
 * legal links, and user preference controls.
 */
import { Image } from "astro:assets";
import ContentRenderer from "@/components/ContentRenderer/ContentRenderer.astro";
import PhoneNumberButton from "@/components/PhoneNumberButton.astro";
import FooterLogo from "@/assets/logo-hymanson-transparent-white.png";
import { siteData } from "@/content/siteData";
import { query, relatedRoots, sortByOrder } from "@/utils/query";
import PreferencesLayout from "./PreferencesLayout.astro";
---

<footer class="mt-auto bg-[linear-gradient(135deg,#020b16_0%,#08335d_100%)] text-white">
  <div class="mx-auto w-full px-6 md:px-10 lg:px-16">
    <div class="grid gap-12 md:grid-cols-2 xl:grid-cols-[minmax(0,1.15fr)_repeat(3,minmax(0,1fr))] xl:gap-10 py-8 lg:pt-16">
      <div class="max-w-sm">
        <a
          href="/"
          class="inline-flex items-center transition-opacity duration-200 hover:opacity-85"
          aria-label={siteData.title}
        >
          <Image
            src={FooterLogo}
            alt="Hymanson Law logo"
            width={132}
            height={132}
            format="png"
            class="h-24 w-24 object-contain sm:h-28 sm:w-28 lg:h-32 lg:w-32"
          />
        </a>
        <p class="mb-6">
          {siteData.description}
        </p>
        <div class="mt-6">
          <PhoneNumberButton
            desktopMode="link"
            iconSize="md"
            className="!text-bg transition-colors duration-200 hover:!text-white"
            textClass="!text-bg text-base leading-none md:text-lg lg:text-xl"
          />
        </div>
      </div>

      <div class="text-lg leading-8 text-white/92">
        <ContentRenderer
          query={relatedRoots("menu-items", "menu", "footer-menu")}
          variant="ListVariant"
          title="Menu"
          description=""
          collectionUrl={undefined}
          className="py-0"
        />
      </div>

      <div class="text-lg leading-8 text-white/92">
        <ContentRenderer
          query={query("areas-of-practice").orderBy(sortByOrder())}
          variant="ListVariant"
          title="Areas of Practice"
          description=""
          collectionUrl={undefined}
          className="py-0"
        />
      </div>

      <div class="text-lg leading-8 text-white/92">
        <ContentRenderer
          query={query("where-we-serve").orderBy(sortByOrder())}
          variant="ListVariant"
          title="Where We Serve"
          description=""
          className="py-0"
        />
      </div>
    </div>

    <div class="py-7 text-sm text-white/78">
      <PreferencesLayout className="justify-start md:justify-center" />

      <ContentRenderer
        query={query("legal").orderBy(sortByOrder())}
        variant="ListVariant"
        title=""
        description=""
        className="py-0 md:hidden"
      />
    </div>

    <div class="border-t py-1 border-white/20">
      <div class="flex flex-col gap-5 text-sm leading-6 text-white/78 lg:flex-row lg:items-center lg:justify-between">
        <p>
          &copy; {new Date().getFullYear()} {siteData.legalName}. All Rights Reserved. Built by{" "}
          <a
            href="https://griffinswebservices.com"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold underline-offset-4 transition hover:text-white hover:underline"
          >
            Griffin&apos;s Web Services
          </a>
        </p>

        <ContentRenderer
          query={query("legal").orderBy(sortByOrder())}
          variant="ListVariant"
          title=""
          description=""
          className="hidden py-0 md:block [&_nav]:flex-row [&_nav]:flex-wrap [&_nav]:items-center [&_nav]:gap-x-8 [&_nav]:gap-y-3"
        />
      </div>
    </div>
  </div>
</footer>
