---
import { Image } from "astro:assets";
import ContactForm from "@/components/Form/forms/ContactForm.astro";
import Icon from "@/components/Icon";
import BuildingsHeroImage from "@/assets/buildings.jpg";
import { animationProps } from "@/integrations/scroll-animations";
import {
  getContactLinks,
  type ContactLink,
} from "@/utils/contactLinks";

export interface Props {
  id?: string;
  className?: string;
  title?: string;
  description?: string;
  items?: ContactLink[];
  hiddenFields?: Record<string, string | number | boolean>;
}

const {
  id,
  className = "",
  title = "Request an Initial Consultation",
  description = "Let us help you navigate your legal journey with the attention and expertise it deserves. Fill out the form, and a member of our team will contact you shortly.",
  items: propItems,
  hiddenFields,
} = Astro.props;

const items = propItems ?? (await getContactLinks());

const featuredPhone =
  items.find((item) => item?.tags?.includes("phone")) ??
  items.find((item) => item?.linkPrefix === "tel:");

const otherItems = featuredPhone
  ? items.filter((item) => item !== featuredPhone)
  : items;

const featuredPhoneHref = featuredPhone?.url;
const featuredPhoneValue =
  featuredPhone?.displayValue ??
  featuredPhone?.description ??
  featuredPhone?.title ??
  "";
const featuredPhoneRaw = featuredPhone?.description ?? featuredPhoneValue;

const sectionAnimation = animationProps("fade-in-scale", {
  once: true,
});
---

<section id={id} class={`py-16 w-full ${className}`.trim()}>
  <div
    {...sectionAnimation}
    class="relative overflow-hidden rounded-[2.5rem] px-6 py-8 sm:px-8 sm:py-10 lg:px-14 lg:py-14"
  >
    <Image
      src={BuildingsHeroImage}
      alt=""
      widths={[768, 1280, 1600]}
      sizes="(min-width: 1280px) 80rem, 100vw"
      class="absolute inset-0 h-full w-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(5,18,33,0.88)_0%,rgba(0,38,73,0.8)_50%,rgba(0,57,107,0.72)_100%)]"></div>

    <div class="relative z-10 grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(22rem,32rem)] lg:items-center lg:gap-12">
      <div class="max-w-2xl text-white">
        <h2 class="max-w-[11ch] font-newsreader text-[3.3rem] leading-[0.9] tracking-[-0.04em] text-white sm:text-[4.25rem] lg:text-[5rem]">
          {title}
        </h2>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/75 sm:text-xl">
          {description}
        </p>

        {
          featuredPhoneValue && (
            <div class="mt-10 flex items-center gap-4 sm:gap-6">
              <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1.35rem] bg-white/12 text-secondary backdrop-blur-sm">
                <Icon icon={featuredPhone?.icon ?? "lu:phone"} size="lg" />
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-white/55">
                  {featuredPhone?.title ?? "Immediate Inquiry"}
                </p>
                {
                  featuredPhoneHref ? (
                    <>
                      <a
                        href={featuredPhoneHref}
                        class="mt-2 block font-newsreader text-3xl leading-none tracking-[-0.03em] text-white transition-colors hover:text-secondary lg:hidden"
                      >
                        {featuredPhoneValue}
                      </a>
                      <button
                        type="button"
                        class="contact-phone-copy mt-2 hidden font-newsreader text-3xl leading-none tracking-[-0.03em] text-white transition-colors hover:text-secondary lg:block"
                        data-phone-raw={featuredPhoneRaw}
                        data-phone-display={featuredPhoneValue}
                        aria-label={`Copy ${featuredPhoneValue}`}
                      >
                        {featuredPhoneValue}
                      </button>
                    </>
                  ) : (
                    <p class="mt-2 font-newsreader text-3xl leading-none tracking-[-0.03em] text-white">
                      {featuredPhoneValue}
                    </p>
                  )
                }
              </div>
            </div>
          )
        }

        {
          otherItems.length > 0 && (
            <ul class="mt-8 flex flex-wrap gap-3">
              {otherItems.map((item) => {
                const itemValue =
                  item?.displayValue ?? item?.description ?? item?.title ?? "";

                return (
                  <li>
                    {item.url ? (
                      <a
                        href={item.url}
                        class="inline-flex items-center rounded-full border border-white/15 bg-white/8 px-4 py-2 text-sm font-medium text-white/85 transition-colors hover:bg-white/14"
                      >
                        {itemValue}
                      </a>
                    ) : (
                      <span class="inline-flex items-center rounded-full border border-white/15 bg-white/8 px-4 py-2 text-sm font-medium text-white/85">
                        {itemValue}
                      </span>
                    )}
                  </li>
                );
              })}
            </ul>
          )
        }
      </div>

      <div class="rounded-[2rem] bg-white p-6 shadow-[0_24px_60px_rgba(5,18,33,0.18)] sm:p-8 lg:p-10">
        <ContactForm hiddenFields={hiddenFields} />
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".contact-phone-copy").forEach((element) => {
    if (element instanceof HTMLButtonElement) {
      const defaultLabel =
        element.getAttribute("aria-label") ?? "Copy phone number";
      const phoneRaw = element.dataset.phoneRaw ?? "";
      const phoneDisplay = element.dataset.phoneDisplay ?? phoneRaw;

      element.addEventListener("click", async () => {
        if (!phoneRaw) return;

        try {
          await navigator.clipboard.writeText(phoneRaw);
          element.setAttribute("aria-label", `Copied ${phoneDisplay}`);
          element.classList.add("text-secondary");
          window.setTimeout(() => {
            element.setAttribute("aria-label", defaultLabel);
            element.classList.remove("text-secondary");
          }, 1600);
        } catch {
          element.setAttribute("aria-label", `Unable to copy ${phoneDisplay}`);
        }
      });
    }
  });
</script>
