---
import FrontmatterImage from "@/components/FrontmatterImage.astro";

interface Props {
  featuredImage?: unknown;
  title?: string;
}

const {
  featuredImage,
  title = "",
} = Astro.props as Props;
---

<div class="not-prose area-practice-body">
  {
    featuredImage && (
      <div class="mb-8 overflow-hidden rounded-[1.75rem] md:mb-10">
        <FrontmatterImage
          src={featuredImage}
          alt={title}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    )
  }

  <div
    class="area-practice-content text-[var(--color-text)] [&>*:first-child]:mt-0 [&_a]:text-[var(--color-primary)] [&_a]:underline [&_a]:underline-offset-[0.14em] [&_h2]:mb-4 [&_h2]:mt-8 [&_h2]:scroll-mt-36 [&_h2]:font-[var(--font-newsreader)] [&_h2]:text-[clamp(2rem,3.1vw,2.85rem)] [&_h2]:leading-[0.98] [&_h2]:tracking-[-0.04em] [&_h2]:text-[var(--color-heading)] [&_h2]:text-balance [&_h3]:mb-3 [&_h3]:mt-7 [&_h3]:scroll-mt-36 [&_h3]:font-[var(--font-newsreader)] [&_h3]:text-[clamp(1.45rem,2.1vw,1.95rem)] [&_h3]:leading-[1.02] [&_h3]:tracking-[-0.03em] [&_h3]:text-[var(--color-heading)] [&_h3]:text-balance [&_li]:my-2 [&_li]:pl-1 [&_li]:text-[clamp(1rem,1.1vw,1.08rem)] [&_li]:leading-[1.6] [&_p]:mb-5 [&_p]:max-w-none [&_p]:text-[clamp(1.02rem,1.2vw,1.16rem)] [&_p]:leading-[1.68] [&_strong]:font-semibold [&_strong]:text-[var(--color-heading)] [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-5 md:[&_h2]:mt-10 md:[&_h3]:mt-8 md:[&_p]:mb-6"
  >
    <slot />
  </div>
</div>

<style>
  .area-practice-body :global(img) {
    display: block;
    height: auto;
    width: 100%;
  }
</style>
