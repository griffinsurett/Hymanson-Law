---
// src/components/Form/forms/ContactForm.astro
/**
 * Contact Form - Astro Version
 * Pure HTML with optional React enhancement via client:idle
 */
import { getCollection } from "astro:content";
import FormWrapper from "@/components/Form/FormWrapper";
import Input from "@/components/Form/inputs/Input";
import Select from "@/components/Form/inputs/Select";
import Checkbox from "@/components/Form/inputs/Checkbox";
import Textarea from "@/components/Form/inputs/Textarea";
import Button from "@/components/Button/Button";

interface Props {
  title?: string;
  description?: string;
  className?: string;
  hiddenFields?: Record<string, string | number | boolean>;
}

const {
  title,
  description,
  className = "",
  hiddenFields = {},
} = Astro.props;
const contactFormId =
  import.meta.env.PUBLIC_FORMSPREE_CONTACT_ID ||
  import.meta.env.PUBLIC_FORMSPREE_ID;

const handleSubmit = async () => {
  throw new Error(
    "Contact form is not configured. Set PUBLIC_FORMSPREE_CONTACT_ID or PUBLIC_FORMSPREE_ID."
  );
};

const practiceAreaEntries = await getCollection("areas-of-practice");
const practiceAreaOptions = practiceAreaEntries
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
  .map((entry) => ({
    value: entry.slug,
    label: entry.data.title,
  }));

const fieldLabelClassName =
  "mb-3 block text-xs font-semibold uppercase tracking-[0.08em] text-heading/70";

const fieldInputClassName =
  "w-full rounded-2xl border border-primary/10 bg-surface px-5 py-4 text-lg text-heading placeholder:text-text/45 focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/15";

const fieldTextareaClassName =
  "w-full rounded-2xl border border-primary/10 bg-surface px-5 py-4 text-lg text-heading placeholder:text-text/45 focus:border-primary/40 focus:outline-none focus:ring-2 focus:ring-primary/15 resize-y";
---

<div class={className}>
  {title && <h2 class="mb-3 text-3xl font-bold text-heading">{title}</h2>}
  {description && <p class="mb-8 text-text">{description}</p>}

  <FormWrapper
    client:idle
    onSubmit={!contactFormId ? handleSubmit : undefined}
    formspreeId={contactFormId}
    useNativeFormSubmission={Boolean(contactFormId)}
    successMessage="Thank you for contacting us! We'll get back to you soon."
    errorMessage="There was an error submitting your form. Please try again."
    resetOnSuccess={true}
    className="w-full"
  >
    <input type="hidden" name="formName" value="Greastro Contact Form" />
    {
      Object.entries(hiddenFields).map(([name, value]) => (
        <input type="hidden" name={name} value={String(value)} />
      ))
    }

    <div class="mb-4 grid gap-4 sm:grid-cols-2">
      <Input
        name="firstName"
        label="First Name"
        type="text"
        required={true}
        minLength={2}
        placeholder="John"
        containerClassName="mb-0"
        labelClassName={fieldLabelClassName}
        inputClassName={fieldInputClassName}
      />

      <Input
        name="lastName"
        label="Last Name"
        type="text"
        required={true}
        minLength={2}
        placeholder="Doe"
        containerClassName="mb-0"
        labelClassName={fieldLabelClassName}
        inputClassName={fieldInputClassName}
      />
    </div>

    <Input
      name="email"
      label="Email Address"
      type="email"
      required={true}
      placeholder="john@example.com"
      containerClassName="mb-4"
      labelClassName={fieldLabelClassName}
      inputClassName={fieldInputClassName}
    />

    <Select
      name="practiceArea"
      label="Practice Area Of Interest"
      required={true}
      options={practiceAreaOptions}
      placeholder="Select a practice area"
      defaultValue=""
      containerClassName="mb-4"
      labelClassName={fieldLabelClassName}
      selectClassName={fieldInputClassName}
    />

    <Textarea
      name="message"
      label="Brief Message"
      required={true}
      minLength={10}
      placeholder="Tell us how we can help..."
      rows={6}
      containerClassName="mb-4"
      labelClassName={fieldLabelClassName}
      textareaClassName={fieldTextareaClassName}
    />

    <Checkbox
      name="privacy"
      required
      containerClassName="mb-6 mt-5"
      labelClassName="flex items-start gap-3 cursor-pointer"
      checkboxClassName="mt-1 h-4 w-4 rounded border-primary/20 text-primary focus:ring-primary/20"
    >
      I have read and agree to the{" "}
      <a
        href="/privacy-policy"
        target="_blank"
        rel="noopener noreferrer"
        class="font-semibold text-primary underline underline-offset-4"
      >
        Privacy Policy
      </a>
    </Checkbox>

    <Button variant="primary" type="submit" className="w-full">
      Submit Request
    </Button>
  </FormWrapper>
</div>
