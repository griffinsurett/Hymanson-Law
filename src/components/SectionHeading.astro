---
export interface Props {
  title?: string;
  eyebrow?: string;
  description?: string;
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6";
  align?: "left" | "center" | "right";
  className?: string;
  eyebrowClass?: string;
  titleClass?: string;
  descriptionClass?: string;
}

const {
  title,
  eyebrow,
  description,
  as = "h2",
  align = "left",
  className = "",
  eyebrowClass = "",
  titleClass = "",
  descriptionClass = "",
} = Astro.props as Props;

const Tag = as;

const alignmentClass = {
  left: "text-left",
  center: "text-center",
  right: "text-right",
}[align];

const headingClass = as === "h1" ? "h1" : as === "h2" ? "h2" : as === "h3" ? "h3" : as === "h4" ? "h4" : as === "h5" ? "h5" : "h6";
---

<div class={`w-full ${alignmentClass} ${className}`}>
  {
    eyebrow && (
      <p class={`mb-4 text-sm font-semibold uppercase tracking-[0.28em] text-secondary ${eyebrowClass}`}>
        {eyebrow}
      </p>
    )
  }

  {
    (title || Astro.slots.has("title")) && (
      <Tag class={`${headingClass} ${titleClass}`.trim()}>
        <slot name="title">{title}</slot>
      </Tag>
    )
  }

  {
    (description || Astro.slots.has("description")) && (
      <p class={`${descriptionClass}`.trim()}>
        <slot name="description">{description}</slot>
      </p>
    )
  }
</div>
