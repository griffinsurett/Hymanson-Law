---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { resolveImageMetadata } from "@/utils/images";

interface Props {
  src?: unknown;
  alt?: string;
  class?: string;
  loading?: "eager" | "lazy";
}

const {
  src,
  alt = "",
  class: className = "",
  loading = "lazy",
} = Astro.props as Props;

const localAssetModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/**/*.{avif,gif,jpeg,jpg,png,svg,webp}",
);

const isRemoteUrl = (value: string) => /^https?:\/\//i.test(value);

const normalizeAssetPath = (value: string): string | null => {
  if (value.startsWith("@/")) return `/src/${value.slice(2)}`;
  if (value.startsWith("/src/")) return value;
  return null;
};

const resolveFromStringPath = async (
  value: string,
): Promise<ImageMetadata | string | undefined> => {
  if (isRemoteUrl(value)) return value;
  const normalizedPath = normalizeAssetPath(value);
  if (!normalizedPath) return undefined;
  const loader = localAssetModules[normalizedPath];
  if (!loader) return undefined;
  const module = await loader();
  return module.default;
};

let resolvedSrc: ImageMetadata | string | undefined;

if (typeof src === "string") {
  resolvedSrc = await resolveFromStringPath(src);
} else {
  const metadata = resolveImageMetadata(src as never);
  if (metadata) {
    resolvedSrc = metadata;
  } else if (
    src &&
    typeof src === "object" &&
    "src" in src &&
    typeof (src as { src?: unknown }).src === "string"
  ) {
    resolvedSrc = await resolveFromStringPath((src as { src: string }).src);
  }
}
---

{
  resolvedSrc && (
    <Image
      src={resolvedSrc}
      alt={alt}
      class={className}
      loading={loading}
    />
  )
}
