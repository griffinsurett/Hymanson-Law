---
import type { BaseVariantProps } from "../ContentRenderer.types";
import CountUpNumber from "@/components/CountUpNumber";

interface StatsItem {
  title?: string;
  value?: number;
  suffix?: string;
  prefix?: string;
  decimals?: number;
}

interface Props extends BaseVariantProps {
  items?: StatsItem[];
}

const { items = [], className = "", id } = Astro.props as Props;
---

<section id={id} class={className}>
  {
    items.length > 0 && (
      <ul class="grid list-none grid-cols-1 gap-3 sm:grid-cols-2 sm:gap-4">
        {items.map((item) => (
          <li class="min-w-0">
            <article class="inline-flex h-full min-h-[7.5rem] w-full flex-col items-center justify-center self-stretch bg-white/30 px-6 py-6 text-center outline outline-1 outline-offset-[-1px] outline-white/30 backdrop-blur-md sm:min-h-[9rem] sm:px-7 sm:py-7">
              <CountUpNumber
                client:visible
                end={item.value ?? 0}
                suffix={item.suffix}
                prefix={item.prefix}
                decimals={item.decimals ?? 0}
                className="font-newsreader text-[3.1rem] font-normal leading-[0.8] text-heading sm:text-[3.7rem] md:text-[4.4rem]"
              />
              <p class="mt-4 text-[0.62rem] font-normal uppercase leading-4 tracking-[0.22em] text-heading sm:text-[0.66rem] md:text-[0.72rem]">
                {item.title}
              </p>
            </article>
          </li>
        ))}
      </ul>
    )
  }
</section>
