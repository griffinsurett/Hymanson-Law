---
// src/components/ContentRenderer/variants/ListVariant.astro
/**
 * List Variant - Vertical stack of links
 * Features: Simple list of links using Button component
 */

import type { BaseVariantProps } from "../ContentRenderer.types";
import Button from "@/components/Button/Button";
import { shouldShowCollectionCTA } from "../utils/helpers";

type Props = BaseVariantProps;

const {
  items = [],
  title,
  description,
  className = "",
  collectionUrl,
  collectionTitle,
  id,
} = Astro.props as Props;

const viewAllText = `See Complete ${collectionTitle || "List"}`;
---

<section id={id} class={`py-6 ${className}`}>
  {
    (title || description) && (
      <div class="mb-5">
        {title && (
          <h2 class="text-sm font-medium tracking-[0.32em] text-white/70 uppercase">
            {title}
          </h2>
        )}
        {description && (
          <p class="max-w-3xl text-sm leading-6 opacity-80">{description}</p>
        )}
      </div>
    )
  }

  {
    items.length > 0 && (
      <nav class="flex flex-col items-start gap-2 list-none">
        {items.map((item) => (
            <Button
              href={item.url}
              className="font-normal text-[inherit] leading-[inherit] no-underline hover:text-[inherit] hover:no-underline [font-family:var(--font-plus-jakarta)] [font-optical-sizing:auto]"
              variant="link"
            >
              {item.displayValue ?? item.title}
            </Button>
        ))}
      </nav>
    )
  }

</section>
