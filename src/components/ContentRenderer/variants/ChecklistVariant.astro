---
import type { BaseVariantProps } from "../ContentRenderer.types";
import ChecklistItem from "@/components/LoopComponents/ChecklistItem.astro";

interface Props extends BaseVariantProps {}

const { items = [], className = "", id } = Astro.props as Props;
---

<section id={id} class={className}>
  {
    items.length > 0 && (
      <ul class="flex flex-wrap items-center gap-x-8 gap-y-4 list-none p-0">
        {items.map((item) => (
          <ChecklistItem title={item.displayValue ?? item.title} url={item.url} />
        ))}
      </ul>
    )
  }
</section>
