---
// src/components/ContentRenderer/variants/ContactVariant.astro
import type { BaseVariantProps } from "../ContentRenderer.types";
import ContactFormSection from "@/layouts/ContactFormSection.astro";

interface Props extends BaseVariantProps {
  columns?: 1 | 2 | 3;
}

const {
  items = [],
  title,
  description,
  className = "",
  id,
} = Astro.props as Props;

const normalizedTitle = typeof title === "string" ? title.trim() : "";
const normalizedDescription =
  typeof description === "string" ? description.trim() : "";

const sectionTitle =
  normalizedTitle && normalizedTitle.toLowerCase() !== "contact us"
    ? normalizedTitle
    : "Request an Initial Consultation";

const sectionDescription =
  normalizedDescription &&
  normalizedDescription.toLowerCase() !== "get in touch with us"
    ? normalizedDescription
    : "Let us help you navigate your legal journey with the attention and expertise it deserves. Fill out the form, and a member of our team will contact you shortly.";

---

<ContactFormSection
  id={id}
  className={className}
  title={sectionTitle}
  description={sectionDescription}
  items={items}
/>
