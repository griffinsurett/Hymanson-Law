---
import Button from "@/components/Button/Button";
import PhoneNumberButton from "@/components/PhoneNumberButton.astro";
import { sharedPhoneNumberButtonProps } from "@/components/phoneNumberButtonConfig";

interface Props {
  inquiryHref?: string;
  mobile?: boolean;
}

const {
  inquiryHref = "#practice-inquiry",
  mobile = false,
} = Astro.props as Props;

const cardClass =
  "rounded-[1.75rem] border border-heading/10 bg-white/88 p-5 shadow-[0_18px_44px_rgba(5,18,33,0.08)] backdrop-blur-sm";
---

{
  mobile ? (
    <div>
      <section class={cardClass}>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary/70">
          Request a Consultation
        </p>
        <h2 class="mt-3 font-newsreader text-[2rem] leading-[0.95] tracking-[-0.03em] text-heading">
          Speak With Our Team
        </h2>
        <p class="mt-3 text-base leading-relaxed text-text">
          Reach out about this practice area and we will follow up with prompt, focused guidance.
        </p>

        <div class="mt-5">
          <PhoneNumberButton
            {...sharedPhoneNumberButtonProps}
            className="transition-colors duration-200 hover:text-primary"
            textClass="text-base leading-none md:text-lg"
          />
        </div>

        <div class="mt-5">
          <Button
            href={inquiryHref}
            variant="primary"
            size="md"
            rightIcon="lu:arrow-right"
            className="w-full justify-between shadow-lg"
          >
            Start Your Inquiry
          </Button>
        </div>
      </section>
    </div>
  ) : (
    <div>
      <section class={cardClass}>
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-primary/70">
          Request a Consultation
        </p>
        <h2 class="mt-3 font-newsreader text-[2.2rem] leading-[0.92] tracking-[-0.035em] text-heading">
          Speak With Our Team
        </h2>
        <p class="mt-3 text-base leading-relaxed text-text">
          Reach out about this practice area and we will follow up with prompt, focused guidance.
        </p>

        <div class="mt-5">
          <PhoneNumberButton
            {...sharedPhoneNumberButtonProps}
            className="transition-colors duration-200 hover:text-primary"
            textClass="text-base leading-none md:text-lg"
          />
        </div>

        <div class="mt-5">
          <Button
            href={inquiryHref}
            variant="primary"
            size="md"
            rightIcon="lu:arrow-right"
            className="w-full justify-between shadow-lg"
          >
            Start Your Inquiry
          </Button>
        </div>
      </section>
    </div>
  )
}
